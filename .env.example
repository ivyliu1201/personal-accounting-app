APP_ENV=local

# Backend
BACKEND_PORT=8080
APP_DEV_USER_ID=dev-user
APP_AUTH_DEV_FALLBACK_ENABLED=true
APP_FIREBASE_ENABLED=false
APP_ALLOWED_USER_EMAILS=your-email@example.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\personal-accounting-firebase-admin.json
# Local Postgres example:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:15432/personal_accounting
# Supabase Postgres example:
SPRING_DATASOURCE_URL=jdbc:postgresql://your-project-ref.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-supabase-db-password
SPRING_FLYWAY_BASELINE_ON_MIGRATE=false

# Frontend
FRONTEND_PORT=5173
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-web-app-id
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:8787

# PostgreSQL
POSTGRES_DB=personal_accounting
POSTGRES_USER=personal_accounting
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=15432

# Firebase Authentication
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_WEB_API_KEY=your-web-api-key

# Worker + Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-pages.pages.dev
# Local AI API example. Production Worker secret must use the deployed Cloud Run URL.
AI_CATEGORY_SERVICE_URL=http://127.0.0.1:8000
AI_CATEGORY_SERVICE_TOKEN=your-ai-category-service-token
